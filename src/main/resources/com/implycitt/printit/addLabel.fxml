<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<fx:root type="AnchorPane"
  fx:controller="com.implycitt.printit.controllers.AddLabelController"
  xmlns:fx="http://javafx.com/fxml/" xmlns="http://javafx.com/javafx/">
  <children>
    <VBox spacing="18.0" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
      <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
      </padding>
      <children>
        <Label text="Add a label" styleClass="form-title" />

        <VBox spacing="6.0">
          <children>
            <Label text="Name" styleClass="form-label" />
            <TextField fx:id="nameField" promptText="Label name" />
          </children>
        </VBox>

        <VBox spacing="6.0">
          <children>
            <Label text="Category" styleClass="form-label" />
            <ChoiceBox fx:id="categoryChoiceBox" maxWidth="Infinity" />
          </children>
        </VBox>

        <VBox spacing="6.0">
          <children>
            <Label text="Subcategories" styleClass="form-label" />
            <TextField fx:id="categoryField" promptText="Comma-separated subcategories" />
          </children>
        </VBox>

        <VBox spacing="6.0">
          <children>
            <Label text="Type" styleClass="form-label" />
            <TextField fx:id="typeField" promptText="Label type" />
          </children>
        </VBox>

        <VBox spacing="6.0">
          <children>
            <Label text="File" styleClass="form-label" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
              <children>
                <Button fx:id="filePickerButton" text="Choose file..." />
                <Text fx:id="filePickerText" text="No file selected" styleClass="form-hint" />
              </children>
            </HBox>
          </children>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <Button fx:id="addLabelButton" text="Add label" onAction="#createLabel" styleClass="primary" maxWidth="Infinity" />
      </children>
    </VBox>
  </children>
</fx:root>
